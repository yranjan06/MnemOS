# MnemOS environment configuration
# Copy to .env and fill in values

# --- Primary LLM (Groq — fast, free tier available) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
LITELLM_MODEL=groq/llama-3.1-8b-instant

# --- HydraDB (memory layer — free sandbox at app.hydradb.com) ---
HYDRA_DB_API_KEY=hdb_xxxxxxxxxxxxxxxxxxxx

# --- Fallback LLM options (uncomment one) ---
# OPENAI_API_KEY=sk-...
# LITELLM_MODEL=openai/gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# LITELLM_MODEL=anthropic/claude-haiku-4-5-20251001

# LITELLM_MODEL=ollama/llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
